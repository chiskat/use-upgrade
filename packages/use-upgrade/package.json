{
  "name": "use-upgrade",
  "version": "1.1.0",
  "description": "A lib can auto detect new versions of your SPA website",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "jsnext:main": "dist/index.esm.js",
  "unpkg": "dist/index.umd.js",
  "jsdelivr": "dist/index.umd.js",
  "typings": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.esm.js",
      "require": "./dist/react/index.cjs.js",
      "default": "./dist/react/index.cjs.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.esm.js",
      "require": "./dist/vue/index.cjs.js",
      "default": "./dist/vue/index.cjs.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "node script/skill.mjs",
    "build": "rollup -c",
    "test": "vitest run",
    "format": "prettier --list-different .",
    "lint": "eslint",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "react hooks",
    "vue hooks",
    "upgrade",
    "website"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chiskat/use-upgrade",
    "directory": "packages/use-upgrade"
  },
  "bugs": {
    "url": "https://github.com/chiskat/use-upgrade/issues"
  },
  "author": "chiskat <1@paperplane.cc> (https://paperplane.cc)",
  "license": "MIT",
  "homepage": "https://use-upgrade.paperplane.cc",
  "peerDependencies": {
    "react": ">=16",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "lodash-es": "^4.17.23",
    "msw": "^2.7.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.34.8",
    "rollup-plugin-delete": "^3.0.0",
    "rollup-plugin-dts": "^6.1.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.13"
  },
  "files": [
    "dist/**",
    "skills/**"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  }
}
