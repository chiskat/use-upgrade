{
  "name": "use-upgrade",
  "version": "0.0.0",
  "description": "A lib can auto detect new versions of your SPA website.",
  "main": "dist/index.cjs.js",
  "typings": "dist/index.d.ts",
  "browser": "dist/index.umd.js",
  "unpkg": "dist/index.umd.js",
  "jsdelivr": "dist/index.umd.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*/index.d.ts",
        "default": "./dist/*/index.esm.js"
      },
      "default": {
        "types": "./dist/*/index.d.ts",
        "default": "./dist/*/index.cjs.js"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "format": "prettier --list-different \"./{src,test}/**/*.ts\"",
    "lint": "eslint \"./{src,test}/**/*.ts\"",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "react hooks",
    "vue hooks",
    "upgrade",
    "website"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chiskat/use-upgrade",
    "directory": "packages/use-upgrade"
  },
  "bugs": {
    "url": "https://github.com/chiskat/use-upgrade/issues"
  },
  "author": "chiskat <1@paperplane.cc> (https://paperplane.cc)",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "vue": "^3.5.13"
  },
  "files": [
    "dist/**",
    "es/**",
    "lib/**"
  ]
}
