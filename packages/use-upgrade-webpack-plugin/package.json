{
  "name": "use-upgrade-webpack-plugin",
  "version": "0.0.0",
  "description": "A tool to help you detect new versions of your websites.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "jsnext:main": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "format": "prettier --list-different \"./{src,test}/**/*.ts\"",
    "lint": "eslint \"./{src,test}/**/*.ts\"",
    "check-types": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chiskat/use-upgrade",
    "directory": "packages/use-upgrade-webpack-plugin"
  },
  "bugs": {
    "url": "https://github.com/chiskat/use-upgrade/issues"
  },
  "keywords": [
    "use-upgrade",
    "upgrade",
    "webpack",
    "webpack plugin"
  ],
  "author": "chiskat <1@paperplane.cc> (https://paperplane.cc)",
  "license": "MIT",
  "files": [
    "es/**",
    "lib/**"
  ]
}
